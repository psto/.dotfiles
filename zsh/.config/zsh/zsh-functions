  rg -l "$@" | fzf | xargs -0 realpath | wl-copy
}

# Get all link from URL
get-urls() {
  if [ -z "$1" ]; then
    echo "Usage: get-urls <url>"
    return 1
  fi
  curl -sL "$1" | htmlq --attribute href a
}

# Select a task from the pending list and start it immediately
tstart() {
  local selected_task=$(task status:pending export | jq -r '.[] | "\(.id) [\(.project // "no project")] \(.description)"' | fzf --reverse --header "Select a task to START")

  if [[ -n "$selected_task" ]]; then
    local id="${selected_task%% *}"

    task "$id" start
  fi
}

# Select a task and set a due time for today
ttime() {
  local task_id=$(task status:pending export | jq -r '.[] | "\(.id) [\(.project)] \(.description)"' | fzf --reverse --header "Set time for today (HH:MM)")

  if [[ -n "$task_id" ]]; then
    echo -n "Enter time (e.g., 14:00): "
    read task_time

    local today=$(date +%Y-%m-%d)
    local id="${task_id%% *}"

    task "$id" modify due:"${today}T${task_time}"
  fi
}

# Annotate a task
tann() {
  local task_id=$(task status:pending export | jq -r '.[] | "\(.id) \(.description)"' | fzf --reverse --header "Add note/annotation")
  if [[ -n "$task_id" ]]; then
    echo -n "Annotation: "
    read note
    task ${task_id%% *} annotate "$note"
  fi
}

# Log to both Taskwarrior and Timewarrior simultaneously
tt-log() {
  if [[ $# -lt 3 || $# -gt 4 ]]; then
    echo "Usage: tt-log \"Task Description\" HH:MM [ - ] HH:MM"
    return 1
  fi

  local desc="$1"
  local start_time="$2"
  # If 4 arguments are passed, ignore the 3rd (the hyphen) and take the 4th
  local end_time="${4:-$3}"
  local today=$(date +%Y-%m-%d)

  echo "Logging to Taskwarrior..."
  task log "${desc}" entry:"${today}T${start_time}:00" end:"${today}T${end_time}:00"

  echo -e "\nLogging to Timewarrior..."
  timew track "${start_time}" - "${end_time}" "${desc}"
}

# Fix the end time of a task in both Taskwarrior and Timewarrior
tt-fix() {
  if [[ $# -lt 2 ]]; then
    echo "Usage:   tt-fix <task_id> <correct_end_time>"
    echo "Example: tt-fix 141 21:00"
    echo "Example: tt-fix 141 2026-06-03T21:00:00 (for specific dates)"
    return 1
  fi

  local task_id="$1"
  local end_input="$2"
  local full_end_iso=""

  # Fetch task details dynamically
  local desc=$(task _get "${task_id}.description" 2>/dev/null)
  local entry_raw=$(task _get "${task_id}.entry" 2>/dev/null)

  if [[ -z "$desc" ]]; then
    echo "Error: Task $task_id not found."
    return 1
  fi

  # Determine the correct date context
  # If user provided a full ISO timestamp, use it. Otherwise, use the task's original start date.
  if [[ "$end_input" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T ]]; then
    full_end_iso="$end_input"
  else
    # Extract just the YYYY-MM-DD from the task's entry timestamp
    local start_date=$(echo "$entry_raw" | cut -d'T' -f1)
    full_end_iso="${start_date}T${end_input}:00"
  fi

  echo "Stopping & completing Taskwarrior task $task_id at $full_end_iso..."
  task "${task_id}" modify status:completed end:"${full_end_iso}"

  echo "\nAdjusting Timewarrior tracking..."
  # If the task is currently active right now, stop it using the absolute timestamp
  if timew | grep -q "Tracking"; then
    timew stop "${full_end_iso}"
  else
    # Dynamically find the most recent interval ID matching the description
    local timew_id=$(timew summary :ids | grep "${desc}" | tail -n 1 | awk '{print $1}')

    if [[ -n "$timew_id" ]]; then
      echo "Adjusting interval ${timew_id} matching '$desc'..."
      timew modify end "${timew_id}" "${full_end_iso}"
    else
      echo "Warning: Could not find a matching Timewarrior interval. Adjusting @1 as fallback."
      timew modify end @1 "${full_end_iso}"
    fi
  fi
}

tzk() {
  local choice
  choice=$(task project:zk status:pending export | jq -r '.[] | "\(.id) | \(.description) \([.tags[]?] | if length > 0 then "[\(join(", "))]" else "" end)"' | \
    fzf --header="Select a Zettelkasten note to start working on" \
        --prompt="Task > " \
        --height=40% \
        --layout=reverse)

  [[ -z "$choice" ]] && return 0

  local task_id
  task_id=$(echo "$choice" | awk -F ' | ' '{print $1}')

  echo "Starting task $task_id..."
  task "$task_id" start

  taskopen "$task_id"
}

# remind
remind() {
    # If no file is explicitly provided in the arguments, append your XDG path
    if [[ "$*" != *".rem"* ]]; then
        command remind -m "$@" "$XDG_CONFIG_HOME/remind/reminders.rem"
    else
        command remind -m "$@"
    fi
}

fnm() {
  unset -f fnm node npm npx
  eval "$(command fnm env --use-on-cd)"
  fnm "$@"
}
node() { fnm env; command node "$@"; }
npm()  { fnm env; command npm "$@"; }
npx()  { fnm env; command npx "$@"; }
