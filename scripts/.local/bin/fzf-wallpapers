#!/bin/bash

NIRI_CONFIG="$HOME/.config/niri/config.kdl"
WALLPAPER_DIR="$HOME/public/pictures/wallpapers/"
CURRENT_WALLPAPER=""

DMS_PID=$(pgrep -x dms 2>/dev/null)
SWAYBG_PID=$(pgrep -n swaybg 2>/dev/null)

if [ -n "$DMS_PID" ]; then
  # Note: Extracting current wallpaper from DMS IPC is tricky without a 'get' command,
  # so we assume empty or rely on the fzf selection.
  MODE="dms"
elif [ -n "$SWAYBG_PID" ]; then
  CURRENT_WALLPAPER=$(tr '\0' ' ' < "/proc/$SWAYBG_PID/cmdline" 2>/dev/null | awk -F ' -i ' '{print $2}' | awk '{print $1}')
  MODE="swaybg"
else
  MODE="dms" # Default to dms
fi

WALLPAPER=$(find "$WALLPAPER_DIR" -type f | fzf --preview "swaybg -i {} -m fill" --preview-window=up:0%)

if [ -n "$WALLPAPER" ]; then
  if [ "$MODE" = "dms" ]; then
    dms ipc call wallpaper set "$WALLPAPER"
  else
    # Fallback/Legacy swaybg behavior
    pkill -x swaybg 2>/dev/null
    sed -i "s|^\(\s*spawn-at-startup \"swaybg\" \"-i\"\s*\"\).*\"\s*\"-m\".*|\1$WALLPAPER\" \"-m\" \"fill\"|" "$NIRI_CONFIG"
    nohup swaybg -i "$WALLPAPER" -m fill >/dev/null 2>&1 &
    disown
  fi

elif [ -n "$CURRENT_WALLPAPER" ] && [ "$MODE" = "swaybg" ]; then
  # Restore previous swaybg if cancelled
  nohup swaybg -i "$CURRENT_WALLPAPER" -m fill >/dev/null 2>&1 &
  disown
fi
