#!/bin/env bash
# @vicinae.schemaVersion 1
# @vicinae.title irw untrack
# @vicinae.mode silent
# @vicinae.icon 📖

selected=$(/home/piotr/.local/bin/irw schedule --raw | awk -F',' '{print substr($0, index($0,$6))}' | vicinae dmenu -p "Select files to untrack")

if [[ -n "$selected" ]]; then
  echo "$selected" | while IFS= read -r line; do
    print -P "%F{blue}==>%f Untracking: $line"

    irw untrack "$line"
  done
else
  print -P "%F{yellow}No files selected.%f"
fi
