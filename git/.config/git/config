[user]
  name = Piotr Stojanow
  email = piotr.stojanow@gmail.com
[core]
  editor = nvim
  excludesfile = /home/piotr/.config/git/gitignore
  pager = delta
[alias]
  diff-words = diff --color-words='[^[:space:]]|([[:alnum:]]|UTF_8_GUARD)+'
  diff-staged = diff --cached
  diff-upstream = !git fetch origin && git diff master origin/master
  dt = "! args=$@; shift $#; nvim -c \"DiffviewOpen $args\""
  evolution = log --oneline -p -S
  history = log --oneline -S
  history-one-file = log --follow --patch --
  last = log -1 HEAD --stat
  lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  pr = pull --rebase
  mergetool = "!nvim -c DiffviewOpen"
	sync-dates = "!f() { git filter-branch -f --env-filter \"export GIT_COMMITTER_DATE=\\\"\\$GIT_AUTHOR_DATE\\\"\" $1..HEAD; }; f"
	ri = "!HASH=$(git lg | fzf --ansi --no-sort --reverse \\\n  --header=\"Select the earliest commit you want to MODIFY (will rebase from its parent)\" \\\n  | grep -oE \"[a-f0-9]{7,}\" | head -1); [ -n \"$HASH\" ] && git rebase -i --committer-date-is-author-date \"$HASH~1\""
[interactive]
  diffFilter = delta --color-only
[add.interactive]
  useBuiltin = false
[delta]
  navigate = true    # use n and N to move between diff sections
  light = false      # set to true if you're in a terminal w/ a light background color
  minus-style                   = syntax "#37222c"
  minus-non-emph-style          = syntax "#37222c"
  minus-emph-style              = syntax "#713137"
  minus-empty-line-marker-style = syntax "#37222c"
  line-numbers-minus-style      = "#914c54"
  plus-style                    = syntax "#20303b"
  plus-non-emph-style           = syntax "#20303b"
  plus-emph-style               = syntax "#2c5a66"
  plus-empty-line-marker-style  = syntax "#20303b"
  line-numbers-plus-style       = "#449dab"
  line-numbers-zero-style       = "#3b4261"
[diff]
  colorMoved = default
  tool = nvim_difftool
[difftool "nvim_difftool"]
  cmd = nvim -c \"packadd nvim.difftool\" -c \"DiffTool $LOCAL $REMOTE\"
[grep]
  lineNumber = true
[merge]
  conflictstyle = zdiff3
  tool = nvimmerge
[mergetool "nvimmerge"]
  cmd = nvim -f -c \"DiffviewOpen\"
[pull]
  ff = only
[push]
  autoSetupRemote = true
[rerere]
	enabled = true
[init]
	defaultBranch = main
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[commit]
	verbose = true
[help]
  autocorrect = prompt
[maintenance]
  auto = true
  strategy = incremental
[credential]
	helper = libsecret
